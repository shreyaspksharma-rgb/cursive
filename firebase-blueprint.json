{
  "entities": {
    "userProfile": {
      "title": "User Profile",
      "description": "Stores user-specific settings and metadata",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "hasSeenWelcome": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "userProgress": {
      "title": "User Progress",
      "description": "Stores the user's puzzle completion progress",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "completedGames": { "type": "array", "items": { "type": "integer" } },
        "userAnswers": { "type": "object" },
        "mistakes": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid"]
    },
    "pitch": {
      "title": "Story Pitch",
      "description": "A user-submitted story or game pitch",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "gameIdea": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "title", "description"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "userProfile",
      "description": "User profile information"
    },
    "/progress/{uid}": {
      "schema": "userProgress",
      "description": "User puzzle progress"
    },
    "/pitches/{pitchId}": {
      "schema": "pitch",
      "description": "User submitted story pitches"
    }
  }
}
